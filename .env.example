# Database (Neon PostgreSQL)
DB_HOST=ep-xxxxx.us-east-2.aws.neon.tech
DB_PORT=5432
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_DATABASE=neondb

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Firebase Storage Buckets
FIREBASE_BUCKET_USER_PROFILES_IMAGES=your-bucket-profiles
FIREBASE_BUCKET_DRIVER_DOCUMENT=your-bucket-driver-docs
FIREBASE_BUCKET_VEHICLE_IMAGES=your-bucket-vehicles
FIREBASE_BUCKET_TRIP_RECEIPTS=your-bucket-receipts

# Firebase Service Account (JSON string - required for production)
# Get this by running: cat environment/serviceAccountKey.json | jq -c .
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Environment
NODE_ENV=development
